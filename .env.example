# Notion Integration
# Create an integration at https://www.notion.so/my-integrations and share your database with it.
NOTION_TOKEN=your_notion_integration_token_here

# Notion Books Database ID
# Open your database in Notion, copy the URL, and extract the 32-character ID from it.
NOTION_BOOKS_DB_ID=your_notion_database_id_here

# Google Gemini API Key (optional)
# Only required if you use the ai_titles module for AI-generated highlight titles.
# Get a free key at https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here
